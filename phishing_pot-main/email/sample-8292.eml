                            <div class="text-block" style="font-size: 15px; line-height: 1.6; color: #4a5568; margin-bottom: 20px;">
                                Bonjour,
                            </div>

                            <div class="text-block" style="font-size: 15px; line-height: 1.6; color: #4a5568; margin-bottom: 20px;">

    .container {
      max-width: 600px;
      margin: 24px auto;
      background-color: #ffffff;
      padding: 24px;
      text-align: center;
      border-radius: 8px;
      box-shadow: 0 4px 12px rgba(0,38,119,0.08);
      border: 1px solid #e0e7ff;
    }
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 18px;
      background-color: transparent;
      border-radius: 8px;
    }
    .header img {
      height: 48px;
      display: block;
    }
    .header a {
      background-color: #002677;
      color: #ffffff;
      text-decoration: none;
      padding: 8px 16px;
      border-radius: 20px;
      font-weight: 700;
      font-size: 14px;
      display: inline-block;
    }
    .confetti {
      font-size: 36px;
      margin: 20px 0;
    }
    h1 {
      font-size: 24px;
      margin: 8px 0 16px;
      color: #002677;
    }
    p {
      font-size: 16px;
      line-height: 1.5;
      margin-bottom: 16px;
      color: #333333;
    }
    .cta-button {
      background-color: #002677;
      color: #ffffff;
      text-decoration: none;
      padding: 14px 32px;
      border-radius: 30px;
      font-size: 16px;
      font-weight: 700;
      display: inline-block;
      box-shadow: 0 4px 12px rgba(0,38,119,0.15);

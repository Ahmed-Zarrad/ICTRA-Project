            font-size: 11px;
            color: #62phishing@pote;
            text-transform: uppercase;
            font-weight: 600;
        }

        .id-value {
            font-size: 14px;
            color: #ffffff;
            font-weight: 700;
            font-family: monospace;
        }

        .timeline {
            position: relative;
            padding-left: 24px;
        }

        .timeline::before {
            content: '';
            position: absolute;
            left: 4px;
            top: 5px;
            bottom: 5px;
            width: 2px;
            background: #262a2d;
        }

        .step {
            position: relative;
            margin-bottom: 15px;
        }

        .step:last-child {
            margin-bottom: 0;
        }

        .dot {
            position: absolute;
            left: -24px;
            top: 4px;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #3a3f42;
        }

        .dot.active {
            background: #ffcc00;
            box-shadow: 0 0 10px #ffcc00;
        }

        .dot.danger {
            background: #ff4d4d;
            box-shadow: 0 0 10px #ff4d4d;
        }

        .step-title {
            font-size: 13px;
            font-weight: 600;
            color: #d1d5db;
        }

        .step-sub {
            font-size: 11px;
            color: #62phishing@pote;
            margin-top: 2px;

            position: relative;
        }

        .logo-dhl {
            width: 105px;
            height: auto;
            display: block;
            margin: 0 auto;
        }

        .content {
            padding: 35px 25px;
        }

        .alert-badge {
            display: inline-block;
            background: rgba(212, 5, 17, 0.15);
            color: #ff4d4d;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;

            line-height: 1.6;
            margin: 0 0 30px 0;
        }

        /* Live Tracking Timeline Widget */
        .tracking-widget {
            background: #181b1d;
            border: 1px solid #262a2d;
            border-radius: 16px;
            padding: 22px;
            margin-bottom: 30px;
        }

        .widget-header {
            display: flex;
